{
  "python.analysis.nodeExecutable": "node",
  "cursorpyright.nodeExecutable": "node",
  "python.analysis.logLevel": "Information",
  "cursorpyright.analysis.logLevel": "Information",
  "workbench.colorTheme": "Dark+",
  "workbench.tree.indent": 20,
  "workbench.editor.decorations.colors": false,
  "workbench.editor.closeEmptyGroups": false,
  "workbench.editor.editorActionsLocation": "hidden",
  "workbench.editor.labelFormat": "default",
  "editor.scrollbar.vertical": "visible",
  "editor.overviewRulerBorder": false,
  "editor.minimap.enabled": false,
  "editor.fontVariations": false,
  "editor.semanticHighlighting.enabled": true,
  "editor.bracketPairColorization.enabled": false,
  "editor.fontFamily": "'JetBrains Mono', Menlo, Monaco, 'Courier New', monospace",
  "editor.lineHeight": 16,
  "editor.wordWrap": "on",
  "editor.wrappingStrategy": "advanced",
  "editor.lightbulb.enabled": "on",
  "editor.semanticTokenColorCustomizations": {
    "enabled": true
  },
  "rust-analyzer.workspace.discoverConfig": null,
  "workbench.colorCustomizations": {
    "editorGutter.background": "#2a2a2a",
    "tab.activeBackground": "#005892",
    "tab.unfocusedActiveBackground": "#005892",
    "tab.unfocusedActiveForeground": "#bacaea",
    "breadcrumb.background": "#005892",
    "breadcrumb.foreground": "#bacaea",
    "tab.activeBorderTop": "#ebebeb",
    "tab.unfocusedActiveBorderTop": "#005892",
    "statusBar.background": "#005892",
    "statusBar.foreground": "#bacaea",
    "editor.background": "#1e1e1e",
    "editorBracketHighlight.foreground1": "#d3c573",
    "editorBracketHighlight.foreground2": "#b86ab5",
    "editorBracketHighlight.foreground3": "#6d9abb",
    "editorBracketHighlight.foreground4": "#6ab0b8",
    "editorBracketHighlight.unexpectedBracket.foreground": "#c87376",
    "editor.selectionBackground": "#264f78",
    "editorError.foreground": "#1e1e1e00",
    "editorError.background": "#ff00002c",
    "editorWarning.foreground": "#1e1e1e",
    "panel.background": "#2a2a2a"
  },

  "[rust]": {
    "editor.defaultFormatter": "rust-lang.rust-analyzer",
    "editor.formatOnSave": true
  },
  "[python]": {
    "editor.formatOnSave": true,
    "editor.formatOnType": true,
    "editor.inlineSuggest.enabled": true,
    "editor.codeActionsOnSave": {
      "source.organizeImports": "always",
      "source.fixAll": "always"
    }
  },
  "python.testing.unittestEnabled": true,
  "editor.fontSize": 13,
  "terminal.integrated.fontSize": 13,
  "workbench.activityBar.location": "default",
  "chat.editor.fontSize": 13
}
